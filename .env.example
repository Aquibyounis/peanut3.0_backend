# Peanut 3.0 Backend Environment Variables Template

# ── Database (PostgreSQL) ──
# Local Fallback Reference: postgresql+asyncpg://peanut:peanut@localhost:5432/peanut_db
DATABASE_URL=postgresql+asyncpg://peanut:peanut@localhost:5432/peanut_db
DATABASE_URL_SYNC=postgresql://peanut:peanut@localhost:5432/peanut_db

# ── Redis (Cache) ──
# Local Fallback Reference: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ── Qdrant (Vector DB) ──
# Local Fallback Reference: http://localhost:6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Groq / LLM ──
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5

# ── JWT / Authentication ──
JWT_SECRET_KEY=peanut-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── SMTP / Email Settings ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=aquibyounis2@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=
CONTACT_RECIPIENT_EMAIL=aquibyounis2@gmail.com

# ── Application Settings ──
APP_NAME="Peanut 3.0"
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
